<!--index.wxml-->
<view class="container">
  <!-- 已登录状态 - 个人信息 -->
  <block wx:if="{{isLoggedIn}}">
    <view class="profile-container">
      <!-- 头像 -->
      <view class="avatar-section">
        <view class="avatar-wrapper" bindtap="handleChangeAvatar">
          <image 
            class="avatar" 
            src="{{userInfo.avatar || 'https://tdesign.gtimg.com/mobile/demos/avatar_1.png'}}" 
            mode="aspectFill"
          />
          <view class="avatar-edit-icon">
            <t-icon name="camera" size="28rpx" color="#fff" />
          </view>
        </view>
        <view class="username-wrapper" bindtap="handleChangeUsername">
          <text class="username">{{userInfo.username || '未设置昵称'}}</text>
          <t-icon name="edit" size="32rpx" color="#999" />
        </view>
      </view>

      <!-- 个人信息卡片 -->
      <view class="info-card">
        <t-cell-group theme="card">
          <t-cell 
            title="邮箱" 
            note="{{userInfo.email || '未绑定'}}"
            leftIcon="mail"
          />
          <t-cell 
            title="学号" 
            note="{{userInfo.cardId || '未设置'}}"
            leftIcon="card"
            arrow
            hover
            bindtap="handleBindCardId"
          />
          <t-cell 
            title="班级" 
            note="{{userInfo.className || '未加入'}}"
            leftIcon="usergroup"
            arrow
            hover
            bindtap="handleJoinClass"
          />
        </t-cell-group>
      </view>

      <!-- 操作按钮 -->
      <view class="action-section">
        <t-button theme="danger" variant="outline" size="large" block bindtap="handleLogout">
          退出登录
        </t-button>
      </view>
    </view>
  </block>

  <!-- 未登录状态 - 登录/注册表单 -->
  <block wx:else>
    <!-- 页面标题 -->
    <view class="header">
      <view class="logo">
        <t-icon name="user-circle" size="120rpx" color="#0052d9" />
      </view>
      <view class="title">{{pageMode === 'login' ? '欢迎登录' : (pageMode === 'register' ? '注册账号' : '重置密码')}}</view>
    </view>

    <!-- 登录模式 -->
    <view class="form-container" wx:if="{{pageMode === 'login'}}">
      <!-- 登录方式切换 -->
      <view class="login-tabs">
        <view class="tab-item {{loginType === 'password' ? 'active' : ''}}" bindtap="switchLoginType" data-type="password">密码登录</view>
        <view class="tab-item {{loginType === 'code' ? 'active' : ''}}" bindtap="switchLoginType" data-type="code">验证码登录</view>
      </view>

      <!-- 邮箱输入 -->
      <view class="input-group">
        <t-input
          label="邮箱"
          placeholder="请输入邮箱"
          type="text"
          value="{{email}}"
          bind:change="onEmailChange"
          clearable
        />
      </view>

      <!-- 密码输入 -->
      <view class="input-group" wx:if="{{loginType === 'password'}}">
        <t-input
          label="密码"
          placeholder="请输入密码"
          type="password"
          value="{{password}}"
          bind:change="onPasswordChange"
          clearable
        />
      </view>

      <!-- 验证码输入 -->
      <view class="input-group code-input" wx:if="{{loginType === 'code'}}">
        <t-input
          label="验证码"
          placeholder="请输入验证码"
          type="number"
          maxlength="{{6}}"
          value="{{verifyCode}}"
          bind:change="onCodeChange"
        />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode">
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </view>
      </view>

      <!-- 登录按钮 -->
      <view class="btn-group">
        <t-button theme="primary" size="large" block loading="{{loading}}" bindtap="handleLogin">登录</t-button>
      </view>

      <!-- 底部链接 -->
      <view class="footer-links">
        <text class="link" bindtap="goToRegister">注册账号</text>
        <text class="link" bindtap="goToReset">忘记密码</text>
      </view>
    </view>

    <!-- 注册模式 -->
    <view class="form-container" wx:if="{{pageMode === 'register'}}">
      <view class="input-group">
        <t-input
          label="邮箱"
          placeholder="请输入邮箱"
          type="text"
          value="{{email}}"
          bind:change="onEmailChange"
          clearable
        />
      </view>

      <view class="input-group code-input">
        <t-input
          label="验证码"
          placeholder="请输入验证码"
          type="number"
          maxlength="{{6}}"
          value="{{verifyCode}}"
          bind:change="onCodeChange"
        />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode">
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </view>
      </view>

      <view class="input-group">
        <t-input
          label="密码"
          placeholder="请设置密码"
          type="password"
          value="{{password}}"
          bind:change="onPasswordChange"
          clearable
        />
      </view>

      <view class="input-group">
        <t-input
          label="确认密码"
          placeholder="请再次输入密码"
          type="password"
          value="{{confirmPassword}}"
          bind:change="onConfirmPasswordChange"
          clearable
        />
      </view>

      <view class="btn-group">
        <t-button theme="primary" size="large" block loading="{{loading}}" bindtap="handleRegister">注册</t-button>
      </view>

      <view class="footer-links">
        <text class="link" bindtap="goToLogin">已有账号，去登录</text>
      </view>
    </view>

    <!-- 重置密码模式 -->
    <view class="form-container" wx:if="{{pageMode === 'reset'}}">
      <view class="input-group">
        <t-input
          label="邮箱"
          placeholder="请输入邮箱"
          type="text"
          value="{{email}}"
          bind:change="onEmailChange"
          clearable
        />
      </view>

      <view class="input-group code-input">
        <t-input
          label="验证码"
          placeholder="请输入验证码"
          type="number"
          maxlength="{{6}}"
          value="{{verifyCode}}"
          bind:change="onCodeChange"
        />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="sendCode">
          {{countdown > 0 ? countdown + 's' : '获取验证码'}}
        </view>
      </view>

      <view class="input-group">
        <t-input
          label="新密码"
          placeholder="请设置新密码"
          type="password"
          value="{{password}}"
          bind:change="onPasswordChange"
          clearable
        />
      </view>

      <view class="input-group">
        <t-input
          label="确认密码"
          placeholder="请再次输入新密码"
          type="password"
          value="{{confirmPassword}}"
          bind:change="onConfirmPasswordChange"
          clearable
        />
      </view>

      <view class="btn-group">
        <t-button theme="primary" size="large" block loading="{{loading}}" bindtap="handleReset">重置密码</t-button>
      </view>

      <view class="footer-links">
        <text class="link" bindtap="goToLogin">返回登录</text>
      </view>
    </view>
  </block>

  <!-- Toast 组件 -->
  <t-toast id="t-toast" />
  <t-message id="t-message" />
</view>